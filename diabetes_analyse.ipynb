import pandas as pd
import seaborn as sns
import matplotlib.pyplot as plt

# retorna dados com duas casas decimais
pd.set_option('display.float_format', lambda x: '%.2f' % x)

# Carregando os dados
df = pd.read_csv('diabetes.csv')

df.head()

# verificr se há dados nulos
print(df.isnull().sum())

# verificaar colunas em que não é coerente ter valor zero
colunas_com_zero= ['Glucose', 'BloodPressure', 'Insulin', 'BMI']
for coluna in colunas_com_zero:
    print(f"Zeros em {coluna}:",(df[coluna]==0).sum())
    
# subtituir os zeros pela média das respectivas colunas
for coluna in colunas_com_zero:
    media = df[coluna].mean()
    df[coluna] = df[coluna].replace(0, media)
    
# soma total de uma coluna
total_gestacao = df['Pregnancies'].sum()
print("Total de gestações:",total_gestacao)

total_insulina = df['Insulin'].sum()
print("Total de insulina: {:.2f}".format(total_insulina))

total_bloodpressure = df['BloodPressure'].sum()
print("Total de pressão arterial: {:.2f}".format(total_bloodpressure))

# média de uma coluna
media_bmi = df['BMI'].mean()
print("Média do BMI: {:.2f}".format(media_bmi))

media_idade = df['Age'].mean()
print("Média da idade: {:.2f}".format(media_idade))

#mediana de uma coluna 
mediana_glicose = df['Glucose'].median()
print("Mediana da glicose: {:.2f}".format(mediana_glicose))

mediana_bloodpressure = df['BloodPressure'].median()
print("Mediana da pressão arterial: {:.2f}".format(mediana_bloodpressure))

mediana_bmi = df['BMI'].median()
print("Mediana do BMI: {:.2f}".format(mediana_bmi))

# valor min ou max de uma coluna
min_glicose = df['Glucose'].min()
print("Valor mínimo da glicose: {:.2f}".format(min_glicose))
max_glicose = df['Glucose'].max()
print("Valor máximo da glicose: {:.2f}".format(max_glicose))

min_bloodpressure = df['BloodPressure'].min()
print("Valor mínimo da pressão arterial:",min_bloodpressure)
max_bloodpressure = df['BloodPressure'].max()
print("Valor máximo da pressão arterial:",max_bloodpressure)

min_bmi = df['BMI'].min()
print("Valor mínimo do BMI:",min_bmi)
max_bmi = df['BMI'].max()
print("Valor máximo do BMI:",max_bmi)

# contagem de casos
total_diabetes = df['Outcome'].sum()
print("Total de casos de diabetes:",total_diabetes)
#variancia de algum valor
variancia_glicose = df['Glucose'].var()
print("Variância da glicose: {:.2f}".format(variancia_glicose))

variancia_bloodpressure = df['BloodPressure'].var()
print("Variância da pressão arterial: {:.2f}".format(variancia_bloodpressure))

variancia_bmi = df['BMI'].var()
print("Variância do BMI: {:.2f}".format(variancia_bmi))

# quantas tem e quantas não tem diabetes
contagem_outcome = df['Outcome'].value_counts()
print("Contagem de casos de diabetes (1) e não diabetes (0):")
print(contagem_outcome)

# porcentagem de casos de diabetes
porcentagem_diabetes = (total_diabetes / len(df)) * 100
print("Porcentagem de casos de diabetes: {:.2f}%".format(porcentagem_diabetes)) 

#  média de IMC das pessoas com diabetes vs sem diabetes
media_bmi_por_grupo = df.groupby('Outcome')['BMI'].mean()
print("Média do BMI por grupo (0 = sem diabetes, 1 = com diabetes):")
print(media_bmi_por_grupo)

# Criando uma coluna de faixa etária
df['Faixa_Etaria'] = pd.cut(df['Age'], bins=[0, 30, 50, 90], labels=['Jovem', 'Adulta', 'Seniora'])

# Somando quantos casos de diabetes existem em cada faixa etária
casos_por_idade = df.groupby('Faixa_Etaria')['Outcome'].sum()
print(f"\nTotal de casos de diabetes por faixa etária:\n{casos_por_idade}")


# gerar estatisticas desrcritivas das colunas
estatisticas_descritivas = df.describe()
print(estatisticas_descritivas)


# comparar a média de Glicose e o total de casos por Faixa Etária
comp_idade = df.groupby('Faixa_Etaria').agg({
    'Glucose': 'mean',
    'Outcome': 'sum'
}).rename(columns={'Outcome': 'Total_Casos_Diabetes'})
comp_idade.round(2)

# comparar a média de glicose com a média de blood pressure
comp_glicose_bp = df.groupby('Outcome').agg({
    'Glucose': 'mean',
    'BloodPressure': 'mean'
}).rename(columns={'Glucose': 'Média_Glicose', 'BloodPressure': 'Média_BloodPressure'})
comp_glicose_bp.round(2)

# comparar skinthickness e BMI
comp_skin_bmi = df.groupby('Outcome').agg({
    'SkinThickness': 'mean',
    'BMI': 'mean'
}).rename(columns={'SkinThickness': 'Média_SkinThickness', 'BMI': 'Média_BMI'})
comp_skin_bmi.round(2)

# comparar a média de idade e o total de casos por faixa etária
comp_idade_casos = df.groupby('Faixa_Etaria').agg({
    'Age': 'mean',
    'Outcome': 'sum'
}).rename(columns={'Outcome': 'Total_Casos_Diabetes'})
comp_idade_casos.round(2)

# comparar a média de  idade com a média de insulina
comp_idade_insulina = df.groupby('Outcome').agg({
    'Age': 'mean',
    'Insulin': 'mean'
}).rename(columns={'Age': 'Média_Idade', 'Insulin': 'Média_Insulina'})
comp_idade_insulina.round(2)

# comparar a média de todas as colunas entre os dois grupos
comparacao_medias = df.groupby('Outcome').mean(numeric_only=True)
comparacao_medias.round(2)
